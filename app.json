{
  "expo": {
    "name": "vault-family-ui",
    "slug": "vault-family-ui",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/vault-family-icons/ic_launcher_512x512.png",
    "scheme": "vaultfamilyui",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1F2E",
        "foregroundImage": "./assets/vault-family-icons/ic_launcher_512x512.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.avdienkosa.vaultfamilyui"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/vault-family-icons/ic_launcher_48x48.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 260,
          "resizeMode": "contain",
          "backgroundColor": "#1A1F2E",
          "dark": {
            "backgroundColor": "#111827"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
